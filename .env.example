# ─────────────────────────────────────────────────────────────
# NOC Incident Management — Required Environment Variables
# Copy this file to .env for local dev (never commit .env)
# Set these in Netlify → Site settings → Environment variables
# ─────────────────────────────────────────────────────────────

# ── Firebase Admin SDK (server-side, Netlify functions) ──────
# Get from Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=corrective-5bf09
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@corrective-5bf09.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----\n"

# ── Firebase Web SDK (fallback, used if Admin SDK unavailable) ─
FIREBASE_API_KEY=AIzaSy...
FIREBASE_APP_ID=1:232500381090:web:...

# ── LINE Notify ───────────────────────────────────────────────
# Get from LINE Developers → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# LINE Group IDs to notify (comma-separated if multiple)
LINE_GROUP_IDS=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Legacy single group (kept for backward compat)
LINE_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Apps Script Webhook (optional LINE proxy) ─────────
# If set, LINE messages are sent via GAS first, then falls back to LINE API directly
GAS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec

# ── Image Upload (ImgBB) ──────────────────────────────────────
# Get from https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_api_key_here

# ── API Protection ───────────────────────────────────────────
# Must match window.NOC_API_KEY in index.html
# TODO: replace with Firebase Auth ID Token when login system is added
NOC_API_SECRET=noc-internal-2024

# ── CORS (optional) ───────────────────────────────────────────
# Restrict API access to your Netlify domain (e.g. https://your-site.netlify.app)
# Leave blank or set to * to allow all origins (not recommended for production)
ALLOWED_ORIGIN=https://your-site.netlify.app

# ── Netlify auto-provided (do not set manually) ───────────────
# URL=https://your-site.netlify.app   ← set automatically by Netlify
